  "sentences": [
    {
      "id": "sent_hsk2_1",
      "lessonId": "lesson_hsk2_shopping",
      "chinese": "这件衣服多少钱？",
      "pinyin": "Zhè jiàn yīfu duōshao qián?",
      "translation": "Bộ quần áo này bao nhiêu tiền?",
      "explanation": "1. 这 (zhè): đây, này.\n2. 件 (jiàn): lượng từ cho quần áo, sự việc.\n3. 衣服 (yīfu): quần áo.\n4. 多少 (duōshao): bao nhiêu.\n5. 钱 (qián): tiền.",
      "audioUrl": ""
    },
    {
      "id": "sent_hsk2_2",
      "lessonId": "lesson_hsk2_shopping",
      "chinese": "这里可以刷卡吗？",
      "pinyin": "Zhèlǐ kěyǐ shuākǎ ma?",
      "translation": "Ở đây có thể quẹt thẻ không?",
      "explanation": "1. 这里 (zhèlǐ): ở đây.\n2. 可以 (kěyǐ): có thể.\n3. 刷卡 (shuākǎ): quẹt thẻ, quẹt tín dụng.\n4. 吗 (ma): trợ từ nghi vấn.",
      "audioUrl": ""
    },
    {
      "id": "sent_hsk3_1",
      "lessonId": "lesson_hsk3_travel",
      "chinese": "请问，去火车站怎么走？",
      "pinyin": "Qǐngwèn, qù huǒchēzhàn zěnme zǒu?",
      "translation": "Xin hỏi, đi đến ga tàu hỏa đi như thế nào?",
      "explanation": "1. 请问 (qǐngwèn): xin hỏi lịch sự.\n2. 去 (qù): đi đến.\n3. 火车站 (huǒchēzhàn): ga tàu hỏa.\n4. 怎么走 (zěnme zǒu): đi đường nào, đi như thế nào.",
      "audioUrl": ""
    },
    {
      "id": "sent_hsk3_2",
      "lessonId": "lesson_hsk3_travel",
      "chinese": "这个地方离这里很远，你最好坐地铁去。",
      "pinyin": "Zhège dìfang lí zhèlǐ hěn yuǎn, nǐ zuìhǎo zuò dìtiě qù.",
      "translation": "Nơi này cách đây rất xa, tốt nhất bạn nên đi tàu điện ngầm.",
      "explanation": "1. 离 (lí): cách.\n2. 远 (yuǎn): xa.\n3. 最好 (zuìhǎo): tốt nhất nên.\n4. 坐 (zuò): ngồi, đi (xe, tàu).\n5. 地铁 (dìtiě): tàu điện ngầm.",
      "audioUrl": ""
    },
    {
      "id": "sent_hsk4_1",
      "lessonId": "lesson_hsk4_office",
      "chinese": "我们必须在下周五前完成这个项目。",
      "pinyin": "Wǒmen bìxū zài xià zhōuwǔ qián wánchéng zhège xiàngmù.",
      "translation": "Chúng ta phải hoàn thành dự án này trước thứ Sáu tuần tới.",
      "explanation": "1. 必须 (bìxū): nhất định phải.\n2. 下周五 (xià zhōuwǔ): thứ Sáu tuần sau.\n3. 完成 (wánchéng): hoàn thành.\n4. 项目 (xiàngmù): dự án, hạng mục.",
      "audioUrl": ""
    }
  ],
